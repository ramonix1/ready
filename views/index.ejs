    <div class="flex w-max animate-[scroll_20s_linear_infinite]">

      <!-- Duplicado para efeito infinito -->
      <% for(let i = 0; i < 4; i++) { %>

        <img src="/images/itg.png" class="h-20 mx-10">
        <img src="/images/mobit.png" class="h-20 mx-10">
        <img src="/images/geosales.png" class="h-20 mx-10">
